Enum reservation_status {
  pending
  paid
  expired
  cancelled
}

Table screenings {
  id bigint [pk, increment]

  title varchar(255) [not null]
  starts_at timestamptz [not null]
  total_seats smallint [not null, note: 'Общий пул мест на сеанс']

  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    starts_at
  }
}

Table reservations {
  id uuid [pk]

  screening_id bigint [not null]

  access_token_hash varchar(64) [not null, unique, note: 'SHA-256 хэш токена управления бронью']

  customer_name varchar(80)
  customer_email varchar(254)

  status reservation_status [not null, default: 'pending']

  expires_at timestamptz [not null]
  paid_at timestamptz
  cancelled_at timestamptz

  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    (screening_id, status, expires_at)
    (status, expires_at)
  }
}

Ref: reservations.screening_id > screenings.id
